{
  "manifest_version": 3, 
  "name": "AI Claim Verifier",
  "version": "1.0",
  "description": "Detect AI-generated content and verify claims",

  "permissions": [],

  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}